{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "npm",
    "analytics": false
  },
  "newProjectRoot": "projects",
  "projects": {
    "credit-fabric-remote": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "less",
          "skipTests": true,
          "changeDetection": "OnPush"
        },
        "@schematics/angular:service": {
          "skipTests": true,
          "type": "service"
        },
        "@schematics/angular:directive": {
          "skipTests": true,
          "type": "directive"
        },
        "@schematics/angular:pipe": {
          "skipTests": true,
          "typeSeparator": "."
        },
        "@schematics/angular:interceptor": {
          "skipTests": true,
          "typeSeparator": "."
        },
        "@schematics/angular:resolver": {
          "skipTests": true,
          "typeSeparator": "."
        },
        "@schematics/angular:guard": {
          "skipTests": true,
          "typeSeparator": "."
        }
      },
      "root": "",
      "sourceRoot": "src",
      "prefix": "cf",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "src/main.ts",
            "tsConfig": "tsconfig.app.json",
            "inlineStyleLanguage": "less",
            "assets": [
              {
                "glob": "**/*",
                "input": "public"
              },
              {
                "glob": "**/*",
                "input": "./node_modules/@ant-design/icons-angular/src/inline-svg/",
                "output": "/assets/"
              },
              {
                "glob": "**/*",
                "input": "node_modules/ngx-extended-pdf-viewer/assets/",
                "output": "assets"
              }
            ],
            "styles": [
              "src/styles.less",
              {
                "input": "public/styles/light.less",
                "bundleName": "light",
                "inject": false
              },
              {
                "input": "public/styles/dark.less",
                "bundleName": "dark",
                "inject": false
              }
            ],
            "stylePreprocessorOptions": {
              "includePaths": ["public/styles"]
            }
          },
          "configurations": {
            "production": {
              "fileReplacements": [
                {
                  "replace": "src/environments/development.ts",
                  "with": "src/environments/production.ts"
                }
              ],
              "optimization": true,
              "extractLicenses": true,
              "outputHashing": "all"
            },
            "testing": {
              "fileReplacements": [
                {
                  "replace": "src/environments/development.ts",
                  "with": "src/environments/testing.ts"
                }
              ],
              "optimization": true,
              "extractLicenses": true,
              "outputHashing": "all"
            },
            "development-server": {
              "optimization": true,
              "extractLicenses": true,
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          }
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "credit-fabric-remote:build:production"
            },
            "development": {
              "buildTarget": "credit-fabric-remote:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "test": {
          "builder": "@angular/build:unit-test"
        }
      }
    }
  }
}

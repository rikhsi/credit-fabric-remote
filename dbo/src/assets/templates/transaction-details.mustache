<?xml version="1.0" encoding="utf-8" ?>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <title>Memorial Order - {{data.docNum}}</title>
  <link rel="preconnect" href="https://fonts.gstatic.com">
  <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <style>

    body {
      font-family: Arial, sans-serif;
      font-size: 14px;
      margin: 20px;
    }
    .container {
      width: 100% !important;
      border: 1px solid #000;
      padding: 20px;
    }
    .section-title {
      font-weight: bold;
      text-align: center;
      margin-top: 10px;
    }
    .grid {
      display: flex;
      margin: 10px 0;
    }
    .label {
      width: 30%;
    }
    .signature-section {
      text-align: center;
    }

    td {
      vertical-align: top;
    }
  </style>
</head>

<body>
<div class="container flex flex-col gap-y-5">
  <div class="section-title">Платёжное поручение</div>

  <div class="w-full grid grid-cols-2">
    <div class="flex gap-x-2 ">
      <div>Номер документа:</div>
      <div>{{ data.docNum }}</div>
    </div>

    <div class="flex gap-x-2 ">
      <div >Дата документа:</div>
      <div>{{data.dateExec}}</div>
    </div>
  </div>

  <table style="width: 100%; border-collapse: collapse;">
    <tr>
      <td style="text-align: left;">Наименование плательщика:</td>
      <td>{{ data.sender.name }}</td>
      <td style="text-align: left;">ИНН плательщика:</td>
      <td>{{ data.sender.tax }}</td>
    </tr>
    <tr>
      <td style="text-align: left;">Счет плательщика:</td>
      <td>{{ data.sender.account }}</td>
      <td style="text-align: left;">ПИНФЛ плательщика:</td>
      <td>{{ data.sender.pinfl }}</td>
    </tr>
    <tr>
      <td style="text-align: left;">Наименование банка плательщика:</td>
      <td>{{ data.sender.bankName }}</td>
      <td style="text-align: left;">Код банка плательщика:</td>
      <td>{{ data.sender.codeFilial }}</td>
    </tr>
    <tr>
      <td style="text-align: left;">Сумма платежа:</td>
      <td colspan="3">{{ data.amount }} {{ data.senderAmount.currency }}</td>
    </tr>

    <tr><td colspan="4" style="height: 20px;"></td></tr>

    <tr>
      <td style="text-align: left;">Наименование получателя:</td>
      <td>{{ data.recipient.name }}</td>
      <td style="text-align: left;">ИНН получателя:</td>
      <td>{{ data.recipient.tax }}</td>
    </tr>
    <tr>
      <td style="text-align: left;">Счет получателя:</td>
      <td>{{ data.recipient.account }}</td>
      <td style="text-align: left;">ПИНФЛ получателя:</td>
      <td>{{ data.recipient.pinfl }}</td>
    </tr>
    <tr>
      <td style="text-align: left;">Наименование банка получателя:</td>
      <td>{{ data.recipient.bankName }}</td>
      <td style="text-align: left;">Код банка получателя:</td>
      <td>{{ data.recipient.codeFilial }}</td>
    </tr>
  </table>

  <div class="grid grid-cols-4">
    <div class="label text-nowrap">Сумма прописью:</div>
    <div class="col-span-3">{{ data.amountInWords }}</div>
  </div>

  <div class="pb-[30px] grid grid-cols-4">
    <div class="label text-nowrap">Назначение платежа:</div>
    <div class="col-span-3">{{ data.prupose.code }} - {{ data.purpose.name }}</div>
  </div>

  {{#data.signs}}
    <div class="signature-section">
      <p>Руководитель <span class="uppercase">"{{ director.firstName }} {{ director.lastName }}"</span></p>
      <p>Глав. бухгалтер <span class="uppercase">"{{ headOfFinance.firstName }} {{ headOfFinance.lastName }}"</span></p>
      <p>____________________________ Проведено банком ____________________________</p>
      <p>Проведён {{ data.transfered}}</p>
    </div>
  {{/data.signs}}
</div>
</body>

</html>

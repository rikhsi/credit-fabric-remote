<?xml version="1.0" encoding="utf-8" ?>
<html lang='en'>

<head>
  <meta charset='UTF-8'>
  <title>{{name}}</title>
  <link rel="preconnect" href="https://fonts.gstatic.com">
  <link
    href="https://fonts.googleapis.com/css2?family=Roboto:ital,wght@0,100;0,400;0,500;0,700;0,900;1,100;1,300;1,500;1,700;1,900&display=swap"
    rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    body {
      font-size: 16px;
      font-family: 'Roboto', sans-serif;
    }

    .border-dashed {
      border-bottom-style: dashed !important;
    }

    th {
      border: 1px solid #5b5b5b;
      border-collapse: collapse;
    }

    td {
      padding: 4px 6px;
      text-align: start;
      border: 1px solid #5b5b5b;
      border-collapse: collapse;
    }

    .page-break {
      page-break-before: always; /* Forces a page break before the element */
    }

  </style>
</head>


<body class="m-3">
<h6 class="my-4 text-center">Операции по документу  №{{ data.card.docNum }} от {{ data.card.docDate }}г.</h6>
<table>
  <thead>
  <tr style="page-break-inside: avoid;">
    <th>Номер документа</th>
    <th>ID транзакций</th>
    <th>Опер день</th>
    <th>Дата выпонения</th>
    <th>Тип операции</th>
    <th>Сумма оплаты</th>
    <th>Остаток</th>
    <th>Состояние проводки</th>
  </tr>
  </thead>

  <tbody>
  {{#data.data}}
    <tr>
      <td class="text-center">{{ documentId }}</td>
      <td class="text-center">{{ transactId }}</td>
      <td>{{ operDate }}</td>
      <td class="text-center">{{ executeTime }}</td>
      <td class="text-center">{{ leadType }}</td>
      <td class="text-end">{{ sumOplata }}</td>
      <td class="text-end">{{ sumOstatok }}</td>
      <td class="text-center">{{ state }}</td>
    </tr>
  {{/data.data}}
  </tbody>
</table>

</body>

</html>
